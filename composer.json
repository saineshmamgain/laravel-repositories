{
    "name": "saineshmamgain/laravel-repositories",
    "type": "library",
    "license": "MIT",
    "description": "A package to create repositories in your laravel applications.",
    "keywords": [
        "laravel",
        "repository",
        "repositories",
        "eloquent"
    ],
    "homepage": "https://github.com/saineshmamgain/laravel-repositories",
    "support": {
        "issues": "https://github.com/saineshmamgain/laravel-repositories/issues",
        "source": "https://github.com/saineshmamgain/laravel-repositories"
    },
    "authors": [
        {
            "name": "saineshmamgain",
            "email": "saineshmamgain@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0|^13.12",
        "illuminate/database": "^11.0|^12.0|^13.12",
        "illuminate/console": "^11.0|^12.0|^13.12"
    },
    "autoload": {
        "psr-4": {
            "SaineshMamgain\\LaravelRepositories\\" : "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "App\\": "vendor/orchestra/testbench-core/laravel/app"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SaineshMamgain\\LaravelRepositories\\LaravelRepositoryServiceProvider"
            ]
        }
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0|^9.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.5|^11.5|^12.0",
        "rector/rector": "^2.0"
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "format:test": "vendor/bin/pint --test",
        "rector": "vendor/bin/rector process",
        "rector:test": "vendor/bin/rector process --dry-run",
        "test": "./vendor/bin/testbench package:test",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "post-autoload-dump": [
            "@php ./vendor/bin/testbench package:discover --ansi"
        ]
    }
}
